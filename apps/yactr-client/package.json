{
	"name": "yactr-client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"api:generate": "openapi-ts && sed -ie \"s/ | null;/;/g\" src/lib/api/generated/types.gen.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@hey-api/openapi-ts": "0.94.0",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/svelte": "^1.1.2",
		"@inlang/paraglide-js": "^2.13.2",
		"@internationalized/date": "^3.12.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.5",
		"@vitest/browser-playwright": "^4.0.18",
		"clsx": "^2.1.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.31.0",
		"flowbite-svelte-icons": "^3.1.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typebox": "^1.1.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"better-auth": "^1.5.4",
		"bits-ui": "^2.16.3",
		"konva": "^10.2.0",
		"mode-watcher": "^1.1.0",
		"ol": "^10.8.0",
		"svelte-dnd-action": "^0.9.69",
		"svelte-konva": "^1.0.1",
		"svelte-openlayers": "^2.1.0",
		"zod": "^4.3.6"
	}
}
