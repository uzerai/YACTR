{
	"name": "yactr-client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"api:generate": "openapi-ts && sed -ie \"s/ | null;/;/g\" src/lib/api/generated/types.gen.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@hey-api/openapi-ts": "0.98.1",
		"@hugeicons/core-free-icons": "^4.2.2",
		"@hugeicons/svelte": "^1.1.4",
		"@inlang/paraglide-js": "^2.22.0",
		"@internationalized/date": "^3.12.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.9.5",
		"@vitest/browser-playwright": "^4.1.10",
		"clsx": "^2.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"flowbite": "^4.0.2",
		"flowbite-svelte": "^1.33.1",
		"flowbite-svelte-icons": "^3.1.0",
		"formsnap": "^2.0.1",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typebox": "^1.3.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.1"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"better-auth": "^1.6.23",
		"bits-ui": "^2.18.1",
		"konva": "^10.3.0",
		"mode-watcher": "^1.1.0",
		"ol": "^10.9.0",
		"svelte-dnd-action": "^0.9.74",
		"svelte-konva": "^1.0.1",
		"svelte-openlayers": "^2.1.0",
